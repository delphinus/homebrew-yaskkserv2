<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.delphinus.yaskkserv2-dict</string>

    <key>ProgramArguments</key>
    <array>
        <string>/Users/jinnouchi.yasushi/git/github.com/delphinus/homebrew-yaskkserv2/bin/build-dict</string>
    </array>

    <!-- 日次。スリープで逃した分は起床時に発火する。再構築は上流に変化があったときだけ。 -->
    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key>
        <integer>4</integer>
        <key>Minute</key>
        <integer>23</integer>
    </dict>

    <key>RunAtLoad</key>
    <false/>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/opt/homebrew/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
        <key>HOME</key>
        <string>/Users/jinnouchi.yasushi</string>
    </dict>

    <key>StandardOutPath</key>
    <string>/Users/jinnouchi.yasushi/Library/Logs/yaskkserv2-dict.log</string>

    <key>StandardErrorPath</key>
    <string>/Users/jinnouchi.yasushi/Library/Logs/yaskkserv2-dict.log</string>

    <key>ProcessType</key>
    <string>Background</string>

    <key>LowPriorityIO</key>
    <true/>

    <key>Nice</key>
    <integer>10</integer>
</dict>
</plist>
